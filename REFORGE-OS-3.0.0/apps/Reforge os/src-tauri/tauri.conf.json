{
  "package": {
    "productName": "REFORGE OS",
    "version": "3.0.0"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "targets": ["nsis", "dmg", "app"],
      "identifier": "com.bootforge.reforge",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": [
        "python/**/*"
      ],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": null,
        "wix": {
          "language": "en-US"
        },
        "nsis": {
          "installMode": "perMachine",
          "allowDowngrades": true,
          "createDesktopShortcut": true,
          "createStartMenuShortcut": true,
          "shortcutName": "REFORGE OS",
          "menuGroup": "REFORGE OS"
        }
      },
      "macOS": {
        "frameworks": [],
        "minimumSystemVersion": "10.13",
        "exceptionDomain": "",
        "signingIdentity": null,
        "entitlements": null,
        "dmg": {
          "sign": false
        }
      }
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "REFORGE OS - Professional Repair Platform",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  }
}
